# .env.example
# Copy this to .env, fill in values, then: chmod 600 .env
# NEVER commit .env — it is in .gitignore

# Resend API key (get from resend.com/api-keys)
RESEND_API_KEY=re_your_key_here

# Sender address — use onboarding@resend.dev for testing,
# or a verified address like reports@gershonconsulting.com for production
MAIL_FROM=onboarding@resend.dev

# Recipient
MAIL_TO=aina.rama@gershonconsulting.com
